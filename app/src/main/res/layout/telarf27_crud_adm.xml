<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerCrudAdm"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-80dp"
            android:layout_marginTop="-80dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- AVATAR CIRCULAR MATERIAL -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="32dp"
            app:cardCornerRadius="41dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- TÍTULO PREMIUM -->
        <TextView
            android:id="@+id/textTituloCrud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Tela de CRUD"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFotoAdm" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO COM BOTÕES PILL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/headerCrudAdm">

        <!-- BOTÃO 1: CRIAR MÍDIA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCriarMidia"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Criar Mídia"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:rippleColor="#40FFFFFF" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- BOTÃO 2: VERIFICAR MÍDIA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonVerificarMidia"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Verificar Mídia"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:rippleColor="#40FFFFFF" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- BOTÃO 3: GERENCIAR USUÁRIOS -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGerenciarUsuarios"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Gerenciar Usuários"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:rippleColor="#40FFFFFF" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>