<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- CAPA DO LIVRO -->
        <LinearLayout
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="90dp"
                android:layout_height="140dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <ImageView
                    android:id="@+id/imgLivro"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/o_alienista_capa"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/textTituloLivro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="O Alienista"
                android:textColor="#1F2E2E"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textAutorLivro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="por Machado de Assis"
                android:textColor="#5F6A6A"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- INFORMAÇÕES -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Validade do Aluguel:"
                android:textColor="#1F2E2E"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textValidade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="10 de agosto de 2026."
                android:textColor="#5F6A6A"
                android:textSize="18sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Dias para o Vencimento:"
                android:textColor="#1F2E2E"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textDiasRestantes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="5 dias."
                android:textColor="#5F6A6A"
                android:textSize="18sp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>