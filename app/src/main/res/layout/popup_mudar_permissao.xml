<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup_rounded"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingVertical="32dp">

    <TextView
        android:id="@+id/textTituloPermissao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mudar permissão de usuário para ADM?"
        android:textColor="@color/biblio_blue"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingMultiplier="1.2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonMudarParaAdm"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Mudar para ADM"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="12dp"
        app:elevation="0dp" />

    <TextView
        android:id="@+id/textCancelarPermissao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:text="Cancelar"
        android:textColor="@color/biblio_blue"
        android:textSize="16sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>