<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="24dp"
    android:background="@drawable/bg_input"
    android:backgroundTint="@color/white"
    android:padding="24dp">

    <!-- TÍTULO PREMIUM -->
    <TextView
        android:id="@+id/txtTituloDialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data de Publicação"
        android:textColor="@color/biblio_blue"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- SUBTÍTULO -->
    <TextView
        android:id="@+id/txtSubtituloDialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Selecione quando o livro foi publicado"
        android:textColor="#666666"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtTituloDialog" />

    <!-- CONTAINER DO CALENDÁRIO (Modo Calendário Limpo) -->
    <FrameLayout
        android:id="@+id/containerCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/txtSubtituloDialog"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <DatePicker
            android:id="@+id/datePicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:datePickerMode="calendar"
            android:headerBackground="@color/biblio_detalhes"
            android:calendarViewShown="false" />
    </FrameLayout>

    <!-- BOTÃO CONFIRMAR PREMIUM -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarData"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Confirmar Data"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="sans-serif-black"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/containerCalendar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>