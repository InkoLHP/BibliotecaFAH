<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- ESQUERDA -->

        <LinearLayout
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/imageLivro"
                android:layout_width="105dp"
                android:layout_height="150dp"
                android:scaleType="centerCrop"
                android:src="@drawable/osda"/>

            <TextView
                android:id="@+id/textTituloLivro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="O Alienista"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:id="@+id/textAutorLivro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Machado de Assis"
                android:textColor="#777777"
                android:textSize="13sp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- DIREITA -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Validade do aluguel:"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/textDataVencimento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 de agosto"
                android:textColor="#666666"
                android:textSize="15sp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dias para o vencimento:"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/textDiasRestantes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 dias"
                android:textColor="#666666"
                android:textSize="15sp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>