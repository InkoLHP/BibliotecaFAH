<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDesejoRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCapaDesejo"
            android:layout_width="90dp"
            android:layout_height="135dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imgCapaDesejo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder" />

                <TextView
                    android:id="@+id/txtSeloIndisponivel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="#E6C62828"
                    android:text="ESGOTADO"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtTituloDesejo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Título do Livro"
            android:textColor="@color/biblio_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/cardCapaDesejo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtAutorDesejo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Autor do Livro"
            android:textColor="#557373"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/txtTituloDesejo"
            app:layout_constraintEnd_toEndOf="@id/txtTituloDesejo"
            app:layout_constraintTop_toBottomOf="@id/txtTituloDesejo" />

        <TextView
            android:id="@+id/txtStatusEstoque"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Disponível para Aluguel"
            android:textColor="#2E7D32"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/txtTituloDesejo"
            app:layout_constraintTop_toBottomOf="@id/txtAutorDesejo" />

        <LinearLayout
            android:id="@+id/layoutBotoesDesejo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="@id/txtTituloDesejo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtStatusEstoque"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoverDesejo"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="118dp"
                    android:layout_height="40dp"
                    android:text="Remover"
                    android:textAllCaps="false"
                    android:textColor="@color/biblio_red"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAlugarDesejo"
                    android:layout_width="116dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="Alugar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/biblio_blue"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLivrariaDesejo"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="+ Minha Livraria"
                android:textAllCaps="false"
                android:textColor="@color/biblio_blue"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="14dp"
                app:strokeColor="@color/biblio_blue"
                app:strokeWidth="1.2dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>