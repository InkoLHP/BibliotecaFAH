<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:padding="20dp">

    <!-- CARD POPUP -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardApagarContaADM"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="26dp"
            android:paddingBottom="24dp">

            <!-- TÍTULO -->
            <TextView
                android:id="@+id/textTituloApagarContaADM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Apagar conta?"
                android:textColor="@color/biblio_blue"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- DESCRIÇÃO -->
            <TextView
                android:id="@+id/textDescricaoApagarContaADM"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="Essa ação não poderá ser desfeita.\nDigite sua senha atual."
                android:textColor="@color/black"
                android:textSize="15sp" />

            <!-- INPUT -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputSenhaApagarContaADM"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:boxBackgroundColor="@color/biblio_bg"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/biblio_blue"
                app:boxStrokeWidth="1dp"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/biblio_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editSenhaApagarContaADM"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@android:color/transparent"
                    android:hint="************"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- BOTÕES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="22dp">

                <!-- CANCELAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonCancelarApagarContaADM"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Cancelar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#D9534F"
                    app:cornerRadius="12dp"
                    app:elevation="2dp" />

                <!-- CONFIRMAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonConfirmarApagarContaADM"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Confirmar"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/biblio_blue"
                    app:cornerRadius="12dp"
                    app:elevation="2dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>