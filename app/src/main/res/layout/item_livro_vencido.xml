<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardBookItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Capa do Livro Moderna (Bordas arredondadas de 12dp via Style corrigido) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgBookCover"
            android:layout_width="90dp"
            android:layout_height="130dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize12dp"
            tools:srcCompat="@drawable/placeholder" />

        <!-- Título do Livro -->
        <TextView
            android:id="@+id/txtBookTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="O Alienista"
            android:textColor="#222222"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/imgMoreOptions"
            app:layout_constraintStart_toEndOf="@id/imgBookCover"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Botão Mais Opções -->
        <ImageView
            android:id="@+id/imgMoreOptions"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_more"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/biblio_blue" />

        <!-- Autor / Data -->
        <TextView
            android:id="@+id/txtBookAuthor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="por Machado de Assis\n18 dez. 2019"
            android:textColor="#666666"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imgBookCover"
            app:layout_constraintTop_toBottomOf="@id/txtBookTitle" />

        <!-- Foto de Perfil do Usuário Arredondada (100% Circular via Style corrigido) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgProfileSmall"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toEndOf="@id/imgBookCover"
            app:layout_constraintTop_toBottomOf="@id/txtBookAuthor"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
            tools:srcCompat="@tools:sample/avatars" />

        <!-- Nome do Usuário -->
        <TextView
            android:id="@+id/txtUserName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Ronaldo Alves"
            android:textColor="#333333"
            android:textSize="14sp"
            app:layout_constraintBottom_toTopOf="@id/txtDuration"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imgProfileSmall"
            app:layout_constraintTop_toTopOf="@id/imgProfileSmall" />

        <!-- Tempo de atraso -->
        <TextView
            android:id="@+id/txtDuration"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="20 Dias"
            android:textColor="@color/biblio_blue"
            android:textSize="13sp"
            android:fontFamily="sans-serif"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/imgProfileSmall"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imgProfileSmall"
            app:layout_constraintTop_toBottomOf="@id/txtUserName" />

        <!-- Separador Visual Embutido -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#EAEAEA"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgBookCover" />

        <!-- Valor da Multa Destacado -->
        <TextView
            android:id="@+id/txtFine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Multa auto: R$20,00"
            android:textColor="@color/biblio_blue"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>