<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerVerificarMidia"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULOS DECORATIVOS -->
        <View
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="-60dp"
            android:layout_marginEnd="70dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO PERFIL -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoADM"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="50dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloTela"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Verificar Mídia"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoADM"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerVerificarMidia"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- PESQUISA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <EditText
                        android:id="@+id/editPesquisaMidia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Pesquisar solicitações..."
                        android:singleLine="true"
                        android:textColor="@color/black"
                        android:textColorHint="#8A8A8A"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/buttonFiltroMidia"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/biblio_blue" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- CARD SOLICITAÇÃO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- TOPO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- CAPA -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="80dp"
                            android:layout_height="120dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/o_alienista_capa" />

                        </com.google.android.material.card.MaterialCardView>

                        <!-- INFO -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="O Senhor dos Anéis - A sociedade do Anel"
                                android:textColor="@color/biblio_blue"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="J. R. R. Tolkien"
                                android:textColor="@color/black"
                                android:textSize="14sp" />

                            <!-- USUÁRIO -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    app:cardCornerRadius="16dp"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="1dp"
                                    app:strokeColor="#EEEEEE">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/user_placeholder" />

                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Ronaldo Alves"
                                    android:textColor="@color/black"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- SOLICITAÇÃO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Solicitação: Audiobook, PDF, Braille"
                        android:textColor="@color/biblio_blue"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- VER SOLICITAÇÕES -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonVerSolicitacoesUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="Ver solicitações do usuário"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@color/biblio_blue"
                        app:cornerRadius="28dp"
                        app:elevation="4dp"
                        app:rippleColor="#33FFFFFF" />

                    <!-- LINHA 1 ACCESSIBILITY -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonEnviarAudiobook"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Enviar Audiobook"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.01"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@color/biblio_blue"
                            app:cornerRadius="24dp"
                            app:elevation="2dp" />

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="wrap_content" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonEnviarPDF"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Enviar PDF"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.01"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@color/biblio_blue"
                            app:cornerRadius="24dp"
                            app:elevation="2dp" />

                    </LinearLayout>

                    <!-- BRAILLE -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonBrailleConcluido"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="Notificar Braille Concluído"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.01"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@color/biblio_blue"
                        app:cornerRadius="24dp"
                        app:elevation="2dp" />

                    <!-- EXCLUIR -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonExcluirSolicitacao"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:text="Excluir Solicitação"
                        android:textAllCaps="false"
                        android:textColor="#D9534F"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:letterSpacing="0.01"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:strokeColor="#D9534F"
                        app:strokeWidth="1.2dp"
                        app:cornerRadius="24dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>