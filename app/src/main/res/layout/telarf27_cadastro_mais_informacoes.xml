<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER PREMIUM DESIGN -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerConfig"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Fundo decorativo circular -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-110dp"
            android:layout_marginTop="-110dp"
            android:alpha="0.2"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Título Centralizado do Formulário -->
        <TextView
            android:id="@+id/txtHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adicionar Mídia – Extras"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:fontFamily="sans-serif-black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO ROLÁVEL (FORMULÁRIO EXTRAS) -->
    <ScrollView
        android:id="@+id/scrollFormulario"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerConfig"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- Campo: Quantidade de Páginas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUANTIDADE DE PÁGINAS"
                android:textColor="@color/biblio_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/etPaginas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Ex: 300"
                    android:inputType="number"
                    android:paddingHorizontal="20dp"
                    android:textColor="#333333"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Campo: Categoria -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATEGORIA"
                android:textColor="@color/biblio_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/etCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Ex: Ficção"
                    android:paddingHorizontal="20dp"
                    android:textColor="#333333"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Campo: Editora -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EDITORA"
                android:textColor="@color/biblio_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/etEditora"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Ex: Editora Unifor"
                    android:paddingHorizontal="20dp"
                    android:textColor="#333333"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Campo: Link da Imagem -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LINK DA IMAGEM DE CAPA"
                android:textColor="@color/biblio_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/etCapa"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="https://linkdaimagem.com"
                    android:paddingHorizontal="20dp"
                    android:textColor="#333333"
                    android:textSize="16sp" />
            </RelativeLayout>

            <!-- Campo: Sinopse (Caixa de texto expandida) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SINOPSE"
                android:textColor="@color/biblio_blue"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="28dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/etSinopse"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="Escreva a sinopse do livro aqui..."
                    android:inputType="textMultiLine"
                    android:padding="20dp"
                    android:textColor="#333333"
                    android:textSize="15sp" />
            </RelativeLayout>

            <!-- Botão Salvar/Avançar Premium -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIrVersoes"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Editar mais informações"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>