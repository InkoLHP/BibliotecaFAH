<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="22dp"
        android:background="#DDDDDD" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:text="Filtros"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="NOME DO AUTOR"
        android:textColor="#666666"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editFiltroAutor"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_input"
        android:hint="Ex: Machado de Assis"
        android:paddingHorizontal="12dp"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="DATA DE PUBLICAÇÃO"
        android:textColor="#666666"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editFiltroData"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_input"
        android:hint="Ex: 1899 ou 10/12/1899"
        android:inputType="date"
        android:paddingHorizontal="12dp"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="DISPONIBILIDADE"
        android:textColor="#666666"
        android:textSize="12sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/radioGroupDisponibilidade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radioDisponivel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disponível" />

        <RadioButton
            android:id="@+id/radioAlugado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Já Alugados" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="CATEGORIA"
        android:textColor="#666666"
        android:textSize="12sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/radioGroupCategoria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <RadioButton
            android:id="@+id/radioOnline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Online" />

        <RadioButton
            android:id="@+id/radioPresencial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Presencial" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSalvarFiltro"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginBottom="12dp"
        android:text="Salvar Filtro"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="8dp"
        app:elevation="2dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonLimparFiltro"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Limpar Filtragem"
        android:textAllCaps="false"
        android:textColor="@color/biblio_blue"
        android:textStyle="bold"
        app:backgroundTint="@color/white"
        app:cornerRadius="8dp"
        app:strokeColor="@color/biblio_blue"
        app:strokeWidth="1dp" />

</LinearLayout>