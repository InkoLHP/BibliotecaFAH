<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerUsuario"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/biblio_detalhes"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- FUNDO DECORATIVO -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginStart="-100dp"
                android:layout_marginTop="-100dp"
                android:alpha="0.3"
                android:background="@drawable/bg_circle"
                android:backgroundTint="@color/white" />

            <!-- ÍCONES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <ImageView
                    android:id="@+id/btnNotificacao"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="@color/black" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btnConfig"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/ic_menu_manage"
                    app:tint="@color/black" />

            </LinearLayout>

        </FrameLayout>

        <!-- FOTO PERFIL -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imagePerfilUsuario"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_marginTop="-40dp"
            android:scaleType="centerCrop"
            android:src="@drawable/user_placeholder"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

        <!-- NOME -->
        <TextView
            android:id="@+id/textNomeUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="João Bobo"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:fontFamily="sans-serif-black" />

        <!-- BEM VINDO -->
        <TextView
            android:id="@+id/textBemVindoUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Bem vindo"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerUsuario"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- CARD PROCURAR -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"/>

            <!-- BOTÕES -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPesquisa"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                android:fontFamily="sans-serif-black"
                android:text="Pesquisa"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:backgroundTint="@color/biblio_dark"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistorico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                android:text="Histórico"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/biblio_dark"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStatusAluguel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                android:text="Status aluguel"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/biblio_dark"
                app:cornerRadius="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvarAlteracoes"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                android:text="Salvar alterações"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/biblio_dark"
                app:cornerRadius="28dp" />

            <!-- BOTÃO SAIR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSairConta"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp"
                android:text="Sair da conta"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/biblio_red"
                app:cornerRadius="28dp" />

            <!-- DESCOBRIR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/biblio_blue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Descobrir"
                    android:textColor="@color/black"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-black" />

            </LinearLayout>

            <!-- LIVROS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- CARD LIVRO -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="100dp"
                                android:layout_height="150dp"
                                android:adjustViewBounds="true"
                                android:scaleType="centerCrop"
                                android:src="@drawable/o_alienista_capa" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:maxLines="2"
                                android:text="O Alienista"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Machado de Assis"
                                android:textColor="#5F6368"
                                android:textSize="14sp" />

                            <com.google.android.material.button.MaterialButton
                                android:layout_width="match_parent"
                                android:layout_height="45dp"
                                android:layout_marginTop="12dp"
                                android:text="Alugar"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:backgroundTint="@color/biblio_blue"
                                app:cornerRadius="10dp" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </HorizontalScrollView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>