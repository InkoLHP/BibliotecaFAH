<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- TÍTULO (Standard 32dp Padding) -->
    <TextView
        android:id="@+id/textTituloRenovacao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:text="Renovação de Aluguel"
        android:textColor="@color/biblio_blue"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- DESCRIÇÃO -->
    <TextView
        android:id="@+id/textDescricaoRenovacao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Por quantos dias a mais você deseja estender o aluguel desse livro?"
        android:textColor="#415E5E"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/textTituloRenovacao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CARD CALENDÁRIO (Material Pill Style) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCalendario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="32dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#F3F0F5"
        app:layout_constraintTop_toBottomOf="@id/textDescricaoRenovacao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <CalendarView
            android:id="@+id/calendarRenovacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:dateTextAppearance="@style/TextAppearance.AppCompat.Body1"
            android:focusedMonthDateColor="@color/biblio_blue"
            android:showWeekNumber="false"
            android:theme="@style/Theme.AppCompat.Light"
            android:unfocusedMonthDateColor="#777777"
            android:weekDayTextAppearance="@style/TextAppearance.AppCompat.Small" />

    </com.google.android.material.card.MaterialCardView>

    <!-- BOTÃO CONFIRMAR (Pill Standard 56dp) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarData"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="32dp"
        android:text="Confirmar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/cardCalendario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- VOLTAR (Aesthetic Link) -->
    <TextView
        android:id="@+id/textVoltarDaRenovacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Voltar"
        android:textColor="@color/biblio_blue"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnConfirmarData"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>