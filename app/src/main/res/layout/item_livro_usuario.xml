<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"> <com.google.android.material.card.MaterialCardView
            android:layout_width="80dp"
            android:layout_height="120dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/imgCapaLivro"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder" />

        </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textTituloLivro"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="O Senhor dos Anéis"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:maxLines="2" android:ellipsize="end" /> <TextView
                android:id="@+id/textAutorLivro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="J. R. R. Tolkien"
                android:textColor="#555555"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

                <TextView
                    android:id="@+id/textIsbnLivro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="ISBN: 8595084750"
                    android:textColor="@color/biblio_blue"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddListaDesejos"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="+ Lista de Desejos"
                    android:textAllCaps="false"
                    android:textColor="@color/biblio_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/biblio_blue"
                    app:strokeWidth="1.2dp" />

            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerMais"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="Ver mais"
            android:textAllCaps="false"
            android:textColor="@color/biblio_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="@color/biblio_blue"
            app:strokeWidth="1.2dp"
            app:cornerRadius="24dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>