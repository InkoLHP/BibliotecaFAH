<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    android:padding="24dp"
    android:background="@drawable/bg_input"
    android:backgroundTint="@color/white">

    <TextView
        android:id="@+id/textTituloReserva"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reservar Livro"
        android:textColor="@color/biblio_blue"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/textSubtituloReserva"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Escolha a data para retirar o livro"
        android:textColor="#666"
        android:textSize="14sp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/textTituloReserva"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <DatePicker
        android:id="@+id/datePickerReserva"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:datePickerMode="calendar"
        android:calendarViewShown="true"
        app:layout_constraintTop_toBottomOf="@id/textSubtituloReserva"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonConfirmarReserva"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirmar Reserva"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginTop="20dp"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toBottomOf="@id/datePickerReserva"/>

</androidx.constraintlayout.widget.ConstraintLayout>